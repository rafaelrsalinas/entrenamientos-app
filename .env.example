# ---- Variables para el frontend (Vite expone solo las que empiezan por VITE_) ----
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon/public key (seguro en cliente)

# ---- Variables sólo para scripts de importación (NO commitear el service role key) ----
SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service role key (bypasea RLS, solo servidor)
IMPORT_USER_ID=00000000-0000-0000-0000-000000000000
